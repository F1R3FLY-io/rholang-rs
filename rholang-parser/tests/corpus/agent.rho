new Cell in {
    agent Cell {
        constructor() {
            Cell!(0)
        } |

        method get(ret) {
            for (@val <<- Cell) {
                ret!(val)
            }
        } |

        method set(val, ret) {
            for (_ <- Cell) {
                Cell!(val) | ret!(true)
            }
        } |

        default(msg, ret) {
            ret!(false)
        }
    }
    |
    new ret in {
        Cell!get(*ret) |
        for (@val <- ret) {
            Cell!set(val + 1, *ret) |
            for (@success <- ret) {
                Cell!?get().
            }
        }
    }
}
