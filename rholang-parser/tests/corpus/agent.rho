new Cell, cellToken in {
  agent Cell {
    constructor(@initialValue) {
      @[*private, *cellToken]!(initialValue)
    } |

    method get() {
      for (@val <<- @[*private, *cellToken]) {
        return!(val)
      }
    } |

    method set(val) {
      for (_ <- @[*private, *cellToken]) {
        @[*private, *cellToken]!(val) | return!()
      }
    } |

    default(...@args) {
      match args {
        [return, ...rest] => @return!()
        [] => Nil
      }
    }
  } |

  // Invoke the constructor to get an instance
  for (myCell <- Cell!?(0)) {
    // Get the current value from the instance
    for (@val <- myCell!?("get")) {
      // Record that value
      @"should be 0"!(val) |
      // In parallel, update the value of the cell
      myCell!?("set", val + 1) ; // Use sequential sugar
      // Get the new value of the cell
      for (@val <- myCell!?("get")) {
        // Record that value
        @"should be 1"!(val)
      }
    }
  }
}
